{
  "name": "multiplayer-dice-game",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:multiplayer-d-ts && npm run build:multiplayer && concurrently --kill-others npm:dev:*",
    "dev:multiplayer": "npm run build:multiplayer -- --watch",
    "dev:sveltekit": "vite dev",
    "dev:storybook": "storybook dev -p 6006 --no-open",
    "build": "npm run build:multiplayer-d-ts && npm run build:multiplayer && vite build",
    "build:multiplayer": "esbuild src/lib/server/multiplayer.ts --bundle --tsconfig=tsconfig.esbuild.json --outfile=dist/multiplayer.js --platform=node --format=esm --external:redis --external:uuid --external:gravatar --external:jwt-decode --external:lodash-es",
    "build:multiplayer-d-ts": "mkdir -p dist; cp src/multiplayer.d.ts dist/",
    "preview": "vite preview",
    "start": "node ./server.js",
    "lint": "svelte-kit sync && concurrently -c \"#c596c7\",\"#676778\",\"#4b32c3\",\"#fafafa\" --kill-others-on-fail \"npm:lint:*\"",
    "lint:prettier": "prettier --check .",
    "lint:svelte-check": "svelte-check --fail-on-warnings",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:stylelint": "stylelint --max-warnings=0 \"src/**/*.{css,svelte}\"",
    "format": "eslint --fix && stylelint --fix \"src/**/*.{css,svelte}\" && prettier --write .",
    "prepare": "husky || true",
    "test": "vitest --passWithNoTests run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --max-warnings 0 --no-ignore",
      "sh -c 'tsc -p tsconfig.json --noEmit'"
    ],
    "*.(c)?js": [
      "eslint --max-warnings 0 --no-ignore"
    ],
    "*.svelte": [
      "svelte-check --fail-on-warnings",
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/sveltekit": "^10.4.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/gravatar": "^1.8.6",
    "@types/jwt-encode": "^1.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jwt-encode": "^1.0.1",
    "lint-staged": "^17.0.5",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.0",
    "storybook": "^10.4.0",
    "stylelint": "^17.12.0",
    "stylelint-config-clean-order": "^8.0.2",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.18.1",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "svelte": "^5.55.9",
    "uuid": "^14.0.0"
  }
}
